#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

if [ -f "Brewfile" ] && [ "$(uname -s)" = "Darwin" ] && [ "${SKIP_BREW:-}" != "1" ] && [ -t 0 ]; then
  brew bundle check >/dev/null 2>&1 || {
    echo -n "==> Install Homebrew dependencies? (y/N): "
    read -r response
    case "$response" in
      [yY][eE][sS]|[yY])
        brew bundle
        ;;
      *)
        ;;
    esac
    echo
  }
fi
echo "==> Installing Go dependencies…"
go mod tidy -e || true

# When STLC_LINK_GO_SDK is set, replace the Go SDK dependency with the
# given path or module path. Used by automated regen workflows where the
# CLI's pinned Go SDK release lags the spec — pointing at the freshly
# generated Go SDK clone (e.g. ../telnyx-go-staging) lets the build see
# new symbols immediately rather than waiting for a release tag.
#
# Local dev is unaffected when the env var is unset.
if [ -n "${STLC_LINK_GO_SDK:-}" ]; then
  echo "==> STLC_LINK_GO_SDK set; linking to $STLC_LINK_GO_SDK"
  ./scripts/link "$STLC_LINK_GO_SDK"
fi
